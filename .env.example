# MEXC webhook-server configuration
# Copy to .env and adjust if needed. NEVER commit .env to git.

# ── Trading defaults (optional overrides) ─────────────────────────────────────
MEXC_DEFAULT_SYMBOL=SOL_USDT
MEXC_DEFAULT_LEVERAGE=1
MEXC_INSTANCE=1
MEXC_PORT=5000

# ── Login ─────────────────────────────────────────────────────────────────────
# Login is done manually in the browser window that opens on startup.
# Seconds to wait for you to finish logging in before giving up (default 300).
MEXC_LOGIN_WAIT_SECONDS=300

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to 1 to save a screenshot on startup / errors
MEXC_TD_DEBUG_SCREENSHOT=0
